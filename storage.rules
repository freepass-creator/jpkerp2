rules_version = '2';

// jpkerp Firebase Storage — 인증 필수, 경로별 역할 분리
// KISA 대응 기준: 외부 crawling 완전 차단, 내부 접근은 로그인 사용자에 한함
service firebase.storage {
  match /b/{bucket}/o {

    // ── 차량 사진 (출고·반납·상품화) ──
    // 업로드: 로그인 사용자
    // 다운로드: 로그인 사용자 (외부 카탈로그는 Firebase getDownloadURL 토큰으로 별도 접근)
    match /photos/{category}/{carSafe}/{fileName} {
      allow read, write: if request.auth != null;
    }

    // ── 이벤트 첨부 (정비·사고·보험 등) ──
    match /events/{uid}/{carNumber}/{ts}/{fileName} {
      allow read, write: if request.auth != null;
    }

    // ── 계약서·문서 ──
    match /contracts/{contractCode}/{fileName} {
      allow read, write: if request.auth != null;
    }

    // ── OCR 처리 문서 ──
    match /ocr/{path=**} {
      allow read, write: if request.auth != null;
    }

    // ── 프로필 / 기타 ──
    match /profiles/{uid}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // ── 기본: 차단 ──
    match /{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
